@model IEnumerable<Emt.Monitor.Models.IncidentViewModel>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Id</th>
            <th>Patient</th>
            <th>Time</th>
            <th>Location</th>
            <th>Crew</th>
            <th>Pulse</th>
            <th>BP</th>
            <th>Temp (°C)</th>
            <th>SpO2</th>
            <th>RR</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model)
        {
            <tr>
                <td>@i.Id</td>
                <td>@i.PatientName</td>
                <td>@i.IncidentAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@i.Location</td>
                <td>@i.CrewMember</td>
                <td>@i.Pulse</td>
                <td>@i.Systolic / @i.Diastolic</td>
                <td>@i.TemperatureC.ToString("F1")</td>
                <td>@i.SpO2</td>
                <td>@i.RespiratoryRate</td>
                <td>
                    <button class="btn btn-sm btn-outline-primary" onclick="showDetails(@i.Id)">
                        Details
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No incidents found matching the criteria.</div>
}
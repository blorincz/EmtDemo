@model IEnumerable<Emt.Monitor.Models.IncidentViewModel>

@{
    ViewData["Title"] = "Incident Monitor";
}

<h1>Incident Monitor</h1>
<p>Sort and filter by patient and date range using the API data.</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <label class="form-label">Patient Name</label>
        <input class="form-control" name="patientName" value="@(ViewData["PatientName"] ?? "")" />
    </div>
    <div class="col-md-3">
        <label class="form-label">From</label>
        <input type="datetime-local" class="form-control" name="from" value="@(ViewData["From"] ?? "")" />
    </div>
    <div class="col-md-3">
        <label class="form-label">To</label>
        <input type="datetime-local" class="form-control" name="to" value="@(ViewData["To"] ?? "")" />
    </div>
    <div class="col-md-3 align-self-end">
        <button class="btn btn-primary">Filter</button>
    </div>
</form>

@if (ViewData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Id</th>
            <th>Patient</th>
            <th>Time</th>
            <th>Location</th>
            <th>Crew</th>
            <th>Pulse</th>
            <th>BP</th>
            <th>Temp (°C)</th>
            <th>SpO2</th>
            <th>RR</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var i in Model)
    {
        <tr>
            <td>@i.Id</td>
            <td>@i.PatientName</td>
            <td>@i.IncidentAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
            <td>@i.Location</td>
            <td>@i.CrewMember</td>
            <td>@i.Pulse</td>
            <td>@i.Systolic / @i.Diastolic</td>
            <td>@i.TemperatureC</td>
            <td>@i.SpO2</td>
            <td>@i.RespiratoryRate</td>
        </tr>
    }
    </tbody>
</table>
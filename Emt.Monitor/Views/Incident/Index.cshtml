@model IEnumerable<Emt.Monitor.Models.IncidentViewModel>

@{
    ViewData["Title"] = "Incident Monitor";
}

<h1>Incident Monitor</h1>
<p>Sort and filter by patient and date range using the API data.</p>

<form method="get" class="row g-2 mb-3" id="filterForm">
    <div class="col-md-3">
        <label class="form-label">Patient Name</label>
        <input class="form-control" name="patientName" id="patientName" value="@(ViewData["PatientName"] ?? "")" />
    </div>
    <div class="col-md-3">
        <label class="form-label">From</label>
        <input type="datetime-local" class="form-control" name="from" id="from" value="@(ViewData["From"] ?? "")" />
    </div>
    <div class="col-md-3">
        <label class="form-label">To</label>
        <input type="datetime-local" class="form-control" name="to" id="to" value="@(ViewData["To"] ?? "")" />
    </div>
    <div class="col-md-3 align-self-end">
        <button class="btn btn-primary" type="submit">Filter</button>
        <button class="btn btn-outline-secondary" type="button" id="refreshBtn">Refresh</button>
    </div>
</form>

<div class="mb-3">
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="autoRefreshToggle">
        <label class="form-check-label" for="autoRefreshToggle">Auto-refresh (every 10 seconds)</label>
    </div>
    <small class="text-muted" id="lastRefreshTime">Last refresh: --</small>
</div>

@if (ViewData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<div id="incidentTableContainer">
    @await Html.PartialAsync("_IncidentTable", Model)
</div>

<!-- Modal -->
<div class="modal fade" id="incidentModal" tabindex="-1" aria-labelledby="incidentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="modalContent">
            <!-- Content loaded dynamically -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let autoRefreshInterval = null;
        let currentFilters = {
            patientName: '@(ViewData["PatientName"]?.ToString() ?? "")',
            from: '@(ViewData["From"]?.ToString() ?? "")',
            to: '@(ViewData["To"]?.ToString() ?? "")'
        };

        // Load table data via AJAX
        async function loadIncidents() {
            const params = new URLSearchParams();
            if (currentFilters.patientName) params.append('patientName', currentFilters.patientName);
            if (currentFilters.from) params.append('from', currentFilters.from);
            if (currentFilters.to) params.append('to', currentFilters.to);

            try {
                const response = await fetch(`/incident/table?${params.toString()}`);
                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('incidentTableContainer').innerHTML = html;
                    updateLastRefreshTime();
                } else {
                    console.error('Failed to load incidents');
                }
            } catch (error) {
                console.error('Error loading incidents:', error);
            }
        }

        // Show incident details in modal
        async function showDetails(incidentId) {
            const modalContent = document.getElementById('modalContent');
            modalContent.innerHTML = '<div class="text-center p-4">Loading...</div>';

            const modal = new bootstrap.Modal(document.getElementById('incidentModal'));
            modal.show();

            try {
                const response = await fetch(`/incident/details/${incidentId}`);
                if (response.ok) {
                    const html = await response.text();
                    modalContent.innerHTML = html;
                } else {
                    modalContent.innerHTML = '<div class="alert alert-danger m-3">Failed to load incident details</div>';
                }
            } catch (error) {
                console.error('Error loading details:', error);
                modalContent.innerHTML = '<div class="alert alert-danger m-3">Error loading incident details</div>';
            }
        }

        // Update last refresh time display
        function updateLastRefreshTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString();
            document.getElementById('lastRefreshTime').textContent = `Last refresh: ${timeString}`;
        }

        // Toggle auto-refresh
        function toggleAutoRefresh(enabled) {
            if (autoRefreshInterval) {
                clearInterval(autoRefreshInterval);
                autoRefreshInterval = null;
            }

            if (enabled) {
                autoRefreshInterval = setInterval(() => {
                    loadIncidents();
                }, 10000); // 10 seconds
            }
        }

        // Handle form submission
        document.getElementById('filterForm').addEventListener('submit', function(e) {
            e.preventDefault();

            // Update current filters
            currentFilters.patientName = document.getElementById('patientName').value;
            currentFilters.from = document.getElementById('from').value;
            currentFilters.to = document.getElementById('to').value;

            // Update URL without full page reload
            const url = new URL(window.location.href);
            if (currentFilters.patientName) url.searchParams.set('patientName', currentFilters.patientName);
            else url.searchParams.delete('patientName');
            if (currentFilters.from) url.searchParams.set('from', currentFilters.from);
            else url.searchParams.delete('from');
            if (currentFilters.to) url.searchParams.set('to', currentFilters.to);
            else url.searchParams.delete('to');
            window.history.pushState({}, '', url);

            // Load incidents with new filters
            loadIncidents();
        });

        // Manual refresh button
        document.getElementById('refreshBtn').addEventListener('click', function() {
            loadIncidents();
        });

        // Auto-refresh toggle
        document.getElementById('autoRefreshToggle').addEventListener('change', function(e) {
            toggleAutoRefresh(e.target.checked);
        });

        // Initial load and setup
        loadIncidents();
        updateLastRefreshTime();

        // Handle browser back/forward navigation
        window.addEventListener('popstate', function() {
            const params = new URLSearchParams(window.location.search);
            currentFilters.patientName = params.get('patientName') || '';
            currentFilters.from = params.get('from') || '';
            currentFilters.to = params.get('to') || '';

            document.getElementById('patientName').value = currentFilters.patientName;
            document.getElementById('from').value = currentFilters.from;
            document.getElementById('to').value = currentFilters.to;

            loadIncidents();
        });
    </script>
}